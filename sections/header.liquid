<style>
  .header {
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 255, 200, 0.2);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 2rem;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    height: 70px;
  }

  .header__logo {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    text-decoration: none;
    background: linear-gradient(90deg, #00ffc8, #ff00aa, #ffdd00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .header__nav {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav a {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: #ccc;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color 0.2s;
  }

  .header__nav a:hover {
    color: #00ffc8;
  }

  .header__icons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #ccc;
    font-size: 1.2rem;
    transition: color 0.2s;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
  }

  .header__icon-btn:hover { color: #ff00aa; }

  .cart-count {
    background: linear-gradient(135deg, #ff00aa, #ffdd00);
    color: #0a0a0f;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 900;
  }
</style>

<header class="header" role="banner">
  <div class="header__inner">
    <a href="{{ routes.root_url }}" class="header__logo">
      {{ section.settings.logo_text | default: shop.name }}
    </a>
    <nav>
      <ul class="header__nav">
        {% for link in linklists[section.settings.menu].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>
    <div class="header__icons">
      <a href="{{ routes.cart_url }}" class="header__icon-btn">
        🛒 <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo Text", "default": "TECHZONE" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}