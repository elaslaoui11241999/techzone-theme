<style>
  .fp { padding: 60px 48px; background: #fff; }
  .fp-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px; }
  .fp-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #f0a500; margin-bottom: 8px; font-family: 'Rajdhani', sans-serif; font-weight: 600; }
  .fp-title { font-size: 26px; font-weight: 400; color: #111; font-family: 'Rajdhani', sans-serif; }
  .fp-all { font-size: 12px; color: #bbb; text-decoration: underline; cursor: pointer; font-family: 'Rajdhani', sans-serif; }
  .fp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 28px; }

  .fp-card { cursor: pointer; }
  .fp-img { height: 220px; overflow: hidden; position: relative; margin-bottom: 16px; background: #f7f7f5; }
  .fp-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .fp-card:hover .fp-img img { transform: scale(1.05); }

  .fp-badge { position: absolute; top: 12px; left: 12px; background: #111; color: #fff; font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 9px; font-family: 'Rajdhani', sans-serif; }
  .fp-stock { position: absolute; top: 12px; right: 12px; background: #e74c3c; color: #fff; font-size: 9px; letter-spacing: 1px; text-transform: uppercase; padding: 4px 9px; font-family: 'Rajdhani', sans-serif; }

  .fp-cat { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #ccc; margin-bottom: 5px; font-family: 'Rajdhani', sans-serif; }
  .fp-name { font-size: 14px; color: #111; line-height: 1.5; margin-bottom: 8px; font-family: 'Rajdhani', sans-serif; }
  .fp-stars { color: #f0a500; font-size: 12px; margin-bottom: 8px; }
  .fp-foot { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid #f0f0f0; padding-top: 12px; }
  .fp-price { font-size: 16px; font-weight: 600; color: #111; font-family: 'Rajdhani', sans-serif; }
  .fp-add { font-size: 11px; color: #aaa; text-decoration: underline; cursor: pointer; font-family: 'Rajdhani', sans-serif; }
  .fp-add:hover { color: #f0a500; }
</style>

<section class="fp">
  <div class="fp-head">
    <div>
      <div class="fp-label">{{ section.settings.tag }}</div>
      <div class="fp-title">{{ section.settings.title }}</div>
    </div>
    {% if section.settings.show_view_all %}
      <a href="{{ collections[section.settings.collection].url }}" class="fp-all">Ver todos →</a>
    {% endif %}
  </div>

  <div class="fp-grid">
    {% assign col = collections[section.settings.collection] %}
    {% for product in col.products limit: section.settings.products_to_show %}
      <div class="fp-card">
        <div class="fp-img">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy">
          {% endif %}
          {% if forloop.first %}
            <div class="fp-badge">Más vendido</div>
            <div class="fp-stock">Solo quedan 5</div>
          {% endif %}
        </div>
        <div class="fp-cat">{{ product.type | default: 'Producto' }}</div>
        <div class="fp-name">{{ product.title }}</div>
        <div class="fp-stars">★★★★★</div>
        <div class="fp-foot">
          <div class="fp-price">{{ product.price | money }}</div>
          <a href="{{ product.url }}" class="fp-add">Ver producto →</a>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "tag", "label": "Etiqueta", "default": "Catálogo" },
    { "type": "text", "id": "title", "label": "Título", "default": "Nuestros productos" },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "range", "id": "products_to_show", "label": "Productos a mostrar", "min": 3, "max": 12, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "show_view_all", "label": "Mostrar Ver todos", "default": true }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}